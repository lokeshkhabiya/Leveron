# Shared runtime
NODE_ENV=development
LOG_LEVEL=info

# HTTP services
PORT=8080
CORS_ORIGIN=http://localhost:3000
MAGIC_LINK_BASE_URL=http://localhost:8080/api/auth
JWT_SECRET=replace-with-a-secure-random-secret
RESEND_API_KEY=replace-with-resend-api-key

# Database (used by Prisma in server/engine/db package)
DATABASE_URL=postgresql://leveron:leveron@localhost:5432/leveron?schema=public

# Redis (used by server/engine/poller)
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend
NEXT_PUBLIC_SERVER_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
